{
  "name": "hyprview",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch ./src/cli.tsx",
    "format": "prettier --write src/**/*",
    "format:check": "prettier --check src/**/*",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "@babel/preset-react": "^7.28.5",
    "ink": "^6.8.0",
    "neverthrow": "^8.2.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.28.5",
    "@types/react": "^19.2.14",
    "bun-types": "^1.3.10",
    "husky": "^9.1.7",
    "ink-testing-library": "^4.0.0",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1"
  },
  "lint-staged": {
    "src/*": [
      "prettier --write"
    ]
  }
}
